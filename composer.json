{
    "name": "williamug/audited",
    "description": "Simple, robust audit logging for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "audit", "logging", "activity"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/auth": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Williamug\\Audited\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Williamug\\Audited\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Williamug\\Audited\\AuditServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
